import pandas as pd
from sklearn.linear_model import LinearRegression

# Dataset
data = {
    "hours": [1, 2, 3, 4, 5],
    "scores": [30, 40, 50, 60, 70]
}

df = pd.DataFrame(data)

X = df[["hours"]]
y = df["scores"]

model = LinearRegression()
model.fit(X, y)

# Predict
print(model.predict([[6]]))
